# Copier en `.env` (jamais commite - voir .gitignore).

# Date ISO 8601 injectee dans le champ `lastUpdated` des JSON.
# En CI, fournie par le workflow (UTC). En local, laisser vide => date du jour (UTC).
PERFP_LAST_UPDATED=

# Optionnel : enrichissement specs/benchmarks via Gemini (DESACTIVE par defaut).
# gputracker.eu n'expose AUCUN indice de perf ; ce champ permettrait de brancher
# une source d'indices plus tard. Le pipeline tourne sans (rien n'est invente).
GEMINI_API_KEY=
